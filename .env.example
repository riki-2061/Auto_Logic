# העתיקו לקובץ בשם .env והזינו את הערכים האמיתיים (אל תעלו את .env לגיט!)

# מפתח ה-API מ-Resend (מתחיל ב-re_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# לאיזה מייל תגיעו הפניות מהאתר (אפשר כמה מופרדים בפסיק)
CONTACT_TO=riki2061@gmail.com

# שולח: בחשבון חינמי ללא דומיין מאומת משתמשים ב-onboarding@resend.dev
# אחרי אימות דומיין ב-Resend — החליפו לכתובת מהדומיין שלכם, למשל:
# RESEND_FROM=Auto Logic <noreply@yourdomain.com>
RESEND_FROM=onboarding@resend.dev

# אופציונלי — פורט (ברירת מחדל 3000)
# PORT=3000
